# ─────────────────────────────────────────────────────────────
# Veritabanı (MySQL / MariaDB) — admin panel + mesajlar + projeler
# Boşsa site statik içerikle çalışmaya devam eder (kırılmaz).
# Örnek: mysql://kullanici:sifre@host:3306/veritabani
DATABASE_URL=

# ─────────────────────────────────────────────────────────────
# Admin paneli girişi (/admin)
ADMIN_EMAIL=
ADMIN_PASSWORD=
# Oturum imzalama anahtarı — uzun rastgele bir değer üret:
#   openssl rand -base64 32
AUTH_SECRET=

# ─────────────────────────────────────────────────────────────
# İletişim formu → Telegram bildirimi (opsiyonel)
# Doldurulmazsa mesaj yine DB'ye düşer; Telegram bildirimi gitmez.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
